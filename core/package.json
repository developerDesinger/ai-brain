{
  "name": "ai-brain",
  "version": "0.2.0",
  "description": "A project-local AI knowledge brain that learns from your codebase and binds every coding agent (Claude Code, Cursor, Codex CLI, Kiro, Copilot, Windsurf, Aider) to follow it.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "keywords": [
    "ai",
    "ai-agent",
    "claude",
    "claude-code",
    "cursor",
    "codex",
    "copilot",
    "kiro",
    "windsurf",
    "aider",
    "mcp",
    "model-context-protocol",
    "anthropic",
    "knowledge-base",
    "rag",
    "code-generation",
    "agent-tools"
  ],
  "homepage": "https://github.com/developerDesinger/ai-brain#readme",
  "bugs": {
    "url": "https://github.com/developerDesinger/ai-brain/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/developerDesinger/ai-brain.git",
    "directory": "core"
  },
  "bin": {
    "brain": "dist/cli.js",
    "brain-mcp": "dist/mcp.js"
  },
  "files": [
    "dist",
    "../bridges",
    "../subagents",
    "../README.md",
    "../LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js dist/mcp.js",
    "dev:mcp": "tsx src/mcp.ts",
    "dev:cli": "tsx src/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "better-sqlite3": "^11.5.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
